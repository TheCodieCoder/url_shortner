<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Analytics — SnapURL' }) %>
</head>
<body>
    <%- include('partials/navbar', { active: 'analytics' }) %>

    <main class="page-main">
        <div class="hero-bg-grid"></div>

        <section class="analytics-section">
            <div class="section-tag">// ANALYTICS</div>
            <h1 class="page-title">Track Your <span class="accent">Links.</span></h1>

            <div class="analytics-search-card">
                <div class="card-label">ENTER SHORT ID OR FULL SHORT URL</div>
                <div class="input-group">
                    <div class="input-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                    </div>
                    <input
                        type="text"
                        id="analyticsInput"
                        class="url-input"
                        placeholder="e.g.  aB3xYz  or  https://snap.url/aB3xYz"
                        autocomplete="off"
                        spellcheck="false"
                    />
                    <button class="shorten-btn" onclick="fetchAnalytics()">
                        <span class="btn-text">Analyze</span>
                        <span class="btn-arrow">→</span>
                    </button>
                </div>
                <div class="error-box" id="analyticsError">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <span id="analyticsErrorMsg">Short ID not found.</span>
                </div>
            </div>

            <div class="dashboard" id="dashboard">
                <div class="dash-header">
                    <div>
                        <div class="section-tag" style="margin-bottom:4px">// RESULTS FOR</div>
                        <div class="dash-short-id" id="dashShortId"></div>
                    </div>
                    <div class="live-badge">
                        <span class="badge-dot"></span> LIVE
                    </div>
                </div>

                <div class="metrics-grid">
                    <div class="metric-card primary-metric">
                        <div class="metric-label">TOTAL CLICKS</div>
                        <div class="metric-value" id="totalClicks">—</div>
                        <div class="metric-bar-bg">
                            <div class="metric-bar-fill" id="clickBar" style="width:0%"></div>
                        </div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">FIRST CLICK</div>
                        <div class="metric-value small" id="firstClick">—</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">LAST CLICK</div>
                        <div class="metric-value small" id="lastClick">—</div>
                    </div>
                </div>

                <div class="history-card">
                    <div class="history-header">
                        <span class="card-label">CLICK HISTORY</span>
                        <span class="history-count" id="historyCount">0 events</span>
                    </div>
                    <div class="history-chart" id="historyChart"></div>
                    <div class="history-list" id="historyList"></div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
    <script>
        function extractShortId(input) {
            input = input.trim();
            try {
                const url = new URL(input);
                const parts = url.pathname.split('/').filter(Boolean);
                return parts[parts.length - 1];
            } catch {
                return input;
            }
        }

        function formatDate(ts) {
            return new Date(ts).toLocaleString('en-IN', {
                day: '2-digit', month: 'short', year: 'numeric',
                hour: '2-digit', minute: '2-digit', hour12: true
            });
        }

        async function fetchAnalytics() {
            const raw = document.getElementById('analyticsInput').value;
            const shortId = extractShortId(raw);
            const errBox = document.getElementById('analyticsError');
            const dashboard = document.getElementById('dashboard');

            errBox.classList.remove('visible');
            dashboard.classList.remove('visible');

            if (!shortId) {
                document.getElementById('analyticsErrorMsg').textContent = 'Please enter a short ID or URL.';
                errBox.classList.add('visible');
                return;
            }

            try {
                const res = await fetch(`/url/${shortId}/analytics`);
                const data = await res.json();

                if (!res.ok) throw new Error(data.message || 'Not found');

                populateDashboard(shortId, data);
                dashboard.classList.add('visible');
            } catch (err) {
                document.getElementById('analyticsErrorMsg').textContent = err.message;
                errBox.classList.add('visible');
            }
        }

        function populateDashboard(shortId, data) {
            const { totalClicks, analytics } = data;

            document.getElementById('dashShortId').textContent = shortId;
            document.getElementById('totalClicks').textContent = totalClicks.toLocaleString();
            document.getElementById('historyCount').textContent = `${totalClicks} event${totalClicks !== 1 ? 's' : ''}`;

            const sorted = [...analytics].sort((a, b) => a.timestamp - b.timestamp);
            document.getElementById('firstClick').textContent = sorted.length ? formatDate(sorted[0].timestamp) : '—';
            document.getElementById('lastClick').textContent = sorted.length ? formatDate(sorted[sorted.length - 1].timestamp) : '—';

            // Animate bar
            setTimeout(() => {
                const pct = Math.min(totalClicks / Math.max(totalClicks, 100) * 100, 100);
                document.getElementById('clickBar').style.width = pct + '%';
            }, 100);

            // Render spark chart
            renderChart(analytics);

            // Render list
            const list = document.getElementById('historyList');
            if (!analytics.length) {
                list.innerHTML = `<div class="no-data">No click events recorded yet.</div>`;
                return;
            }
            list.innerHTML = [...sorted].reverse().map((item, i) => `
                <div class="history-item" style="animation-delay:${i * 40}ms">
                    <div class="event-index">#${sorted.length - i}</div>
                    <div class="event-dot"></div>
                    <div class="event-time">${formatDate(item.timestamp)}</div>
                    <div class="event-ts">${item.timestamp}</div>
                </div>
            `).join('');
        }

        function renderChart(analytics) {
            const chart = document.getElementById('historyChart');
            if (!analytics.length) { chart.innerHTML = ''; return; }

            // Group by day
            const counts = {};
            analytics.forEach(({ timestamp }) => {
                const day = new Date(timestamp).toLocaleDateString('en-IN', { day: '2-digit', month: 'short' });
                counts[day] = (counts[day] || 0) + 1;
            });

            const entries = Object.entries(counts);
            const max = Math.max(...entries.map(e => e[1]), 1);
            const bars = entries.map(([day, count]) => {
                const h = Math.max((count / max) * 100, 8);
                return `
                    <div class="chart-col">
                        <div class="chart-tooltip">${count} click${count !== 1 ? 's' : ''}</div>
                        <div class="chart-bar" style="height:${h}%" title="${day}: ${count}"></div>
                        <div class="chart-label">${day}</div>
                    </div>`;
            }).join('');

            chart.innerHTML = `<div class="chart-bars">${bars}</div>`;
        }

        document.getElementById('analyticsInput').addEventListener('keydown', e => {
            if (e.key === 'Enter') fetchAnalytics();
        });
    </script>
</body>
</html>
